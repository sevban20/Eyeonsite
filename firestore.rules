rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isWorkspaceOwner(workspaceId) {
      return isAuthenticated() && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sbilisim18@gmail.com" && request.auth.token.email_verified == true));
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Monitors
    match /monitors/{monitorId} {
      allow read: if isAuthenticated() && (isWorkspaceOwner(resource.data.workspaceId) || isAdmin());
      // Allow the pinger to read monitors (unauthenticated read is okay for now, but we'll restrict it to specific fields if possible)
      allow read: if true; 
      allow create: if isAuthenticated() && isWorkspaceOwner(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && (isWorkspaceOwner(resource.data.workspaceId) || isAdmin());
      // Allow the pinger to update lastChecked and currentStatus if it has the system key
      allow update: if request.resource.data.systemKey == "Sevban2026!." && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastChecked', 'currentStatus', 'systemKey']);
      allow delete: if isAuthenticated() && (isWorkspaceOwner(resource.data.workspaceId) || isAdmin());
    }

    // Ping Logs
    match /pingLogs/{logId} {
      allow read: if true; // Keep unauthenticated read for health check for now
      allow read: if isAuthenticated() && (isWorkspaceOwner(resource.data.workspaceId) || isAdmin());
      // Allow the pinger to create logs if it has the system key
      allow create: if request.resource.data.systemKey == "Sevban2026!."; 
      allow delete: if isAdmin();
    }

    // Alert Channels
    match /alertChannels/{channelId} {
      allow read: if isAuthenticated() && (isWorkspaceOwner(resource.data.workspaceId) || isAdmin());
      allow create: if isAuthenticated() && isWorkspaceOwner(request.resource.data.workspaceId);
      allow update: if isAuthenticated() && (isWorkspaceOwner(resource.data.workspaceId) || isAdmin());
      allow delete: if isAuthenticated() && (isWorkspaceOwner(resource.data.workspaceId) || isAdmin());
    }
  }
}
