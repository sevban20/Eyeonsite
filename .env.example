# DATABASE_URL: PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/uptimesaas?schema=public"

# JWT_SECRET: Secret key for signing authentication tokens
# Generate with: openssl rand -base64 64
JWT_SECRET="generate-a-long-random-string-here"

# APP_URL: The public URL of your application (used for email verification links)
APP_URL="https://yourdomain.com"

# MONITOR_SYSTEM_KEY: Internal pinger auth secret
MONITOR_SYSTEM_KEY="monitor-pinger-secret-2026"

# PORT & NODE_ENV
PORT=3000
NODE_ENV=production

# ─── SMTP Settings (required for email verification) ───────────────────────────
# Use any SMTP provider: Gmail, SendGrid, Mailgun, Resend, etc.
# Gmail example: host=smtp.gmail.com, port=587, use App Password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="UptimeSaaS <noreply@yourdomain.com>"

# ─── OAuth (Infrastructure ready — enable when keys obtained) ───────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

